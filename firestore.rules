rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Users: can read own doc, baker storefronts are public
    // Allow unverified read for basic profile setup, but write requires auth
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Products: bakers can write own, all auth users can read
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isVerified()
        && request.auth.uid == resource.data.bakerId;
      allow create: if isVerified()
        && request.auth.uid == request.resource.data.bakerId;
    }

    // Ingredients: only owning baker can read/write
    match /ingredients/{ingredientId} {
      allow read, write: if isVerified()
        && request.auth.uid == resource.data.bakerId;
      allow create: if isVerified()
        && request.auth.uid == request.resource.data.bakerId;
    }

    // Orders: baker or customer involved can read/write
    match /orders/{orderId} {
      allow read: if isVerified()
        && (request.auth.uid == resource.data.bakerId
         || request.auth.uid == resource.data.customerId);
      allow create: if isVerified();
      allow update: if isVerified()
        && (request.auth.uid == resource.data.bakerId
         || request.auth.uid == resource.data.customerId);
    }

    // Reviews: public read, only authenticated writers after delivery
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isVerified()
        && request.auth.uid == request.resource.data.customerId;
    }

    // Surplus: public read, only baker can write
    match /surplusItems/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isVerified()
        && request.auth.uid == resource.data.bakerId;
      allow create: if isVerified()
        && request.auth.uid == request.resource.data.bakerId;
    }

    // Wishlists: only owning customer
    match /wishlists/{wishlistId} {
      allow read, write: if isVerified()
        && request.auth.uid == resource.data.customerId;
    }

    // Delivery schedules: baker can manage own
    match /deliverySchedules/{scheduleId} {
      allow read, write: if isVerified()
        && request.auth.uid == resource.data.bakerId;
    }
  }
}
