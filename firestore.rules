rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Convenience: public read allowed, writes require authenticated
    function canWrite() {
      return isAuthenticated();
    }

    function isOrderCustomer() {
      return isAuthenticated() && request.auth.uid == request.resource.data.customerId;
    }

    function isOrderBaker() {
      return isAuthenticated() && request.auth.uid == request.resource.data.bakerId;
    }

    function isValidCustomerOrderCancel() {
      return isOrderCustomer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'placed';
    }

    function isValidBakerOrderUpdate() {
      return isOrderBaker()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'inventoryDeducted', 'capacityWarning', 'capacityWarningMessage'])
        && request.resource.data.status != resource.data.status;
    }

    // Users: profiles readable by authenticated users (for baker info), write only by self
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Notifications: only owning user can read/update, anyone authenticated can create
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Products: bakers can write own, all users can read (storefront needs public URLs)
    match /products/{productId} {
      allow read: if true;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
      allow update, delete: if canWrite() && request.auth.uid == resource.data.bakerId;
    }

    // Ingredients: only owning baker can read/write
    match /ingredients/{ingredientId} {
      allow read, write: if canWrite() && request.auth.uid == resource.data.bakerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.customerId
            || request.auth.uid == resource.data.bakerId);

      // Customers may create orders only for themselves.
      allow create: if canWrite()
        && request.auth.uid == request.resource.data.customerId;

      // Status transitions and inventory guard updates only.
      allow update: if isValidCustomerOrderCancel() || isValidBakerOrderUpdate();

      // Optional: disallow deletes
      allow delete: if false;
    }

    // Reviews:
    // - Public read (storefront shared URLs)
    // - Write requires verified auth AND delivered order ownership
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if canWrite()
        && request.auth.uid == request.resource.data.customerId
        && request.resource.data.customerId == get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.customerId
        && request.resource.data.bakerId == get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.bakerId
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'delivered'
        // Prevent overwriting an existing review
        && !exists(/databases/$(database)/documents/reviews/$(reviewId));

      allow update, delete: if false;
    }

    // Surplus items:
    // - Public read for discovery/URLs
    // - Write only for verified baker owner
    match /surplusItems/{itemId} {
      allow read: if true;

      allow create: if canWrite()
        && request.auth.uid == request.resource.data.bakerId;

      allow update, delete: if canWrite()
        && request.auth.uid == resource.data.bakerId;
    }

    // Wishlists: private per customer (not publicly exposed)
    match /wishlists/{wishlistId} {
      allow read: if canWrite() && request.auth.uid == resource.data.customerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.customerId;
      allow update, delete: if canWrite() && request.auth.uid == resource.data.customerId;
    }

    // Delivery schedules: baker can manage own
    match /deliverySchedules/{scheduleId} {
      allow read, write: if canWrite() && request.auth.uid == resource.data.bakerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
    }

    // Photo Analyses: private per baker
    match /photo_analyses/{analysisId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.bakerId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.bakerId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.bakerId;
    }

    // Usage Counters: private per user
    match /usage_counters/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
