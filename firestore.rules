rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAuthenticated() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Convenience: public read allowed, writes require authenticated
    function canWrite() {
      return isAuthenticated();
    }

    // Users: private by default
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Notifications: only owning user can read/update
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Products: bakers can write own, all users can read (storefront needs public URLs)
    match /products/{productId} {
      allow read: if true;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
      allow update, delete: if canWrite() && request.auth.uid == resource.data.bakerId;
    }

    // Ingredients: only owning baker can read/write
    match /ingredients/{ingredientId} {
      allow read, write: if canWrite() && request.auth.uid == resource.data.bakerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
    }

    // Orders: authenticity enforced on create + participants can read/update
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.bakerId
            || request.auth.uid == resource.data.customerId);

      // Customer/baker can create only for themselves
      allow create: if canWrite()
        && (request.auth.uid == request.resource.data.customerId
            || request.auth.uid == request.resource.data.bakerId);

      // Participant updates (status transitions should be validated at app/backend; kept permissive here)
      allow update: if canWrite()
        && (request.auth.uid == resource.data.bakerId
            || request.auth.uid == resource.data.customerId);

      // Optional: disallow deletes
      allow delete: if false;
    }

    // Reviews:
    // - Public read (storefront shared URLs)
    // - Write requires verified auth AND "delivered order only"
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if canWrite()
        && request.auth.uid == request.resource.data.customerId
        && (get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status
            == 'delivered')
        // Prevent overwriting an existing review
        && !exists(/databases/$(database)/documents/reviews/$(reviewId));

      allow update, delete: if false;
    }

    // Surplus items:
    // - Public read for discovery/URLs
    // - Write only for verified baker owner
    match /surplusItems/{itemId} {
      allow read: if true;

      allow create: if canWrite()
        && request.auth.uid == request.resource.data.bakerId;

      allow update, delete: if canWrite()
        && request.auth.uid == resource.data.bakerId;
    }

    // Wishlists: private per customer (not publicly exposed)
    match /wishlists/{wishlistId} {
      allow read: if canWrite() && request.auth.uid == resource.data.customerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.customerId;
      allow update, delete: if canWrite() && request.auth.uid == resource.data.customerId;
    }

    // Delivery schedules: baker can manage own
    match /deliverySchedules/{scheduleId} {
      allow read, write: if canWrite() && request.auth.uid == resource.data.bakerId;
      allow create: if canWrite() && request.auth.uid == request.resource.data.bakerId;
    }
  }
}
